# Hugo build artifacts
.hugo_build.lock
# Default Hugo output dir (publishDir is set to docs/ which IS committed for GitHub Pages)
public/
# Hugo local server resources
resources/_gen/

# Node modules (if using npm/yarn for themes or tools)
node_modules/
package-lock.json
yarn.lock

# Logs and temporary files
*.log
*.tmp
*.bak
*.swp

# OS generated files
.DS_Store
Thumbs.db

# IDE/editor files
.vscode/
.idea/
*.iml

# Backup files (e.g., from text editors)
*~
